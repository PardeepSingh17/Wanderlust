<% layout("/layouts/boilerplate") %>
<body>
    
    <div class="row">
        <div class="col-8 offset-2">
    <form method="post" action="/listing" novalidate class="needs-validation" enctype="multipart/form-data">
        <h3>Create New Listing</h3><br>
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listing[title]" class="form-control" required>
            <div class="invalid-feedback">Title needed</div>
        </div>
       
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required></textarea>
            <div class="invalid-feedback">Please enter some discription.</div>
        </div>
        
        <div class="mb-3">
            <label for="image" class="form-label">Upload image</label>
            <input type="file" name="listing[image]" class="form-control">
        </div>
       
        <div class="row">
            <div class="mb-3 col-md-3">
                <label for="price" class="form-label">Price</label>
                <input type="number" name="listing[price]" class="form-control" required>
                <div class="invalid-feedback">Price required</div>
            </div>

            <div class="mb-3 col-md-8">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="listing[country]" class="form-control" required>
                <div class="invalid-feedback">Country required</div>
            </div>
        </div>
        
       
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" class="form-control" required>
            <div class="invalid-feedback">Location required</div>
        </div><br><br>
       
        
        
        <button class="btn btn-dark">Add lisitng</button><br><br>
    </form>
    </div>
    </div>
</body>
